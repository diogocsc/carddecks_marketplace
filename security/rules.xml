<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="rule_marketplace_purchase_own" model="ir.rule">
            <field name="name">Marketplace purchases: own only</field>
            <field name="model_id" ref="model_carddecks_marketplace_purchase"/>
            <field name="domain_force">[('buyer_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user')), (4, ref('base.group_portal'))]"/>
        </record>

        <record id="rule_marketplace_seller_own" model="ir.rule">
            <field name="name">Marketplace seller: own only</field>
            <field name="model_id" ref="model_carddecks_marketplace_seller"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user')), (4, ref('base.group_portal'))]"/>
        </record>

        <record id="rule_marketplace_entitlement_own" model="ir.rule">
            <field name="name">Marketplace entitlements: own only</field>
            <field name="model_id" ref="model_carddecks_marketplace_entitlement"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user')), (4, ref('base.group_portal'))]"/>
        </record>
    </data>
</odoo>

